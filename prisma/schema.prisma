generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  email             String?
  name              String?
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  // IMAP-specific fields (nullable; only set when provider = 'imap')
  imapHost          String?
  imapPort          Int?
  smtpHost          String?
  smtpPort          Int?
  encryptedPassword String? @db.Text
  encryptionIv      String?
  encryptionTag     String?

  // Health / sync status (applies to all providers)
  isHealthy         Boolean   @default(true)
  lastSyncAt        DateTime?
  lastError         String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails            Email[]

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  emails        Email[]
  onboardingCompleted Boolean @default(false)
}

model Email {
  id              String   @id @default(cuid())
  userId          String
  accountId       String?  // Track which account fetched this email
  gmailId         String?
  outlookId       String?
  providerMessageId String? // Provider-agnostic id (used for IMAP; Gmail/Outlook keep their existing columns)
  threadId        String
  subject         String
  fromName        String?
  fromEmail       String
  toEmail         String
  snippet         String?
  body            String?  @db.Text
  isRead          Boolean  @default(false)
  isStarred       Boolean  @default(false)
  isArchived      Boolean  @default(false)
  labels          String[] @default([])
  receivedAt      DateTime

  // AI-generated fields
  aiSummary       String?  @db.Text
  aiPriorityScore Int?
  aiPriorityLabel String?
  aiActions       Json?
  aiUrgency       String?
  aiWhyItMatters  String?
  aiNextSteps     String?
  aiCategory      String?
  aiPriorityFactors Json?
  aiConfidence     String?
  // aiEmbedding     Vector(384)? // pgvector extension disabled for now

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, threadId])
  @@index([userId, isArchived])
  @@index([gmailId])
  @@index([outlookId])
  @@index([accountId, providerMessageId])
  @@index([userId, accountId, receivedAt(sort: Desc)])
  @@unique([userId, gmailId])
  @@unique([userId, outlookId])
  @@unique([accountId, providerMessageId])
}
